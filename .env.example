# MeroMausam — Nepal Weather Platform
# Copy this to .env and fill in your values

# Email (use Gmail with App Password, or Brevo/Mailjet free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=alerts@meromausam.np

# App URL (used in confirmation emails)
APP_URL=http://localhost

# Optional: set to production domain when deploying
# APP_URL=https://meromausam.np
